# ============================================
# World Monitor — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values you need.
# Local development loads .env.local automatically for both Vite and the local API sidecar.
# All keys are optional — the dashboard works without them,
# but the corresponding features will be disabled.
#
#   cp .env.example .env.local
#
# ============================================


# ------ AI Summarization & Classification ------

# LocalAI OpenAI-compatible chat completions endpoint.
# When both URL and model are configured, LocalAI is preferred over cloud providers.
LOCALAI_API_URL=
LOCALAI_MODEL=

# Optional. Leave empty when the LocalAI server does not require authentication.
LOCALAI_API_KEY=

# Optional. Abort an unavailable LocalAI request before the local Vite proxy times out.
# LOCALAI_REQUEST_TIMEOUT_MS=25000

# Hugging Face Inference Providers / OpenAI-compatible router
# Cloud provider for AI summaries, country briefs, and headline classification.
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN= 

# Optional: override Hugging Face model or router endpoint.
# HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# HF_API_URL=https://router.huggingface.co/v1/chat/completions

# Alibaba Cloud DashScope / Qwen 2.5 1.5B Instruct
# Optional fallback provider for AI summaries, country briefs, and headline classification.
# Get yours at: https://www.alibabacloud.com/help/en/model-studio/get-api-key
DASHSCOPE_API_KEY=

# Optional: override the default DashScope OpenAI-compatible endpoint.
# DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions


# ------ Cross-User Cache (Vercel — Upstash Redis) ------

# Used to deduplicate AI calls and cache risk scores across visitors.
# Create a free Redis database at: https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ------ Market Data (Vercel) ------

# Finnhub (primary stock quotes — free tier available)
# Register at: https://finnhub.io/
FINNHUB_API_KEY=


# ------ Energy Data (Vercel) ------

# U.S. Energy Information Administration (oil prices, production, inventory)
# Register at: https://www.eia.gov/opendata/
EIA_API_KEY=


# ------ Economic Data (Vercel) ------

# FRED (Federal Reserve Economic Data)
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=


# ------ Aircraft Tracking (Vercel) ------

# Wingbits aircraft enrichment (owner, operator, type)
# Contact: https://wingbits.com/
WINGBITS_API_KEY=

# FlightAware AeroAPI (current and scheduled flights inbound to Cuba)
# Register at: https://www.flightaware.com/aeroapi/portal/
FLIGHTAWARE_AEROAPI_KEY=

# Optional: shared server cache duration; minimum 300 seconds, default 1800.
# FLIGHTAWARE_CACHE_TTL_SECONDS=1800


# ------ Conflict & Protest Data (Vercel) ------

